{
  "name": "remix-the-docs",
  "private": true,
  "type": "module",
  "dependencies": {
    "front-matter": "^4.0.2",
    "marked": "^17.0.1",
    "oxfmt": "catalog:",
    "remix": "workspace:*",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@types/dom-navigation": "^1.0.6",
    "@types/hast": "^3.0.4",
    "@types/node": "catalog:",
    "@types/semver": "^7.5.8",
    "pagefind": "^1.3.0",
    "shiki": "^3.22.0",
    "typedoc": "^0.28.19",
    "typescript": "catalog:"
  },
  "scripts": {
    "build": "pnpm run --filter \".\" --parallel \"/^build:/\"",
    "build:demos": "node --import remix/node-tsx src/generate/build-demos.ts",
    "build:public": "mkdir -p build/public && cp public/* build/public",
    "predev": "pnpm run build",
    "dev:server": "node --watch --import remix/node-tsx src/server/index.ts",
    "dev": "NODE_ENV=development pnpm run dev:server",
    "docs": "node src/generate/index.ts",
    "docs:debug": "DEBUG=1 node src/generate/index.ts",
    "prerender": "node --import remix/node-tsx src/prerender/index.ts",
    "prerender:serve": "npx http-server -p 44100 build/site",
    "serve": "node --import remix/node-tsx src/server/index.ts",
    "test": "remix test",
    "typecheck": "tsc --noEmit"
  }
}

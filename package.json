{
  "name": "remix-the-web",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@oxlint/plugins": "^1.57.0",
    "@typescript/native-preview": "catalog:",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.4",
    "prettier": "^3.3.3",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-language-server": "catalog:"
  },
  "engines": {
    "node": ">=24.3.0"
  },
  "scripts": {
    "postinstall": "test -n \"${CI:-}\" || pnpm --filter @remix-run/ui exec playwright install",
    "bootstrap": "node ./scripts/bootstrap.ts",
    "build": "pnpm -r build",
    "changes:preview": "node ./scripts/changes-preview.ts",
    "changes:validate": "node ./scripts/changes-validate.ts",
    "changes:version": "node ./scripts/changes-version.ts",
    "clean": "git clean -fdX -e '!/.env' .",
    "codegen": "pnpm -r run codegen",
    "docs": "cd docs && pnpm run docs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate-remix": "node ./scripts/generate-remix.ts",
    "lint": "oxlint . -A all --quiet",
    "lint:fix": "oxlint . -A all --fix --quiet",
    "pr-preview": "node ./scripts/pr-preview.ts",
    "setup-installable-branch": "node ./scripts/setup-installable-branch.ts",
    "test": "pnpm --parallel run test",
    "test:bun": "pnpm --parallel --if-present run test:bun",
    "test:changed": "node ./scripts/run-changed-workspaces.ts test",
    "typecheck": "pnpm -r typecheck",
    "typecheck:changed": "node ./scripts/run-changed-workspaces.ts typecheck"
  },
  "workspaces": [
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}

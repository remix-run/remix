{
  "name": "@remix-run/fs",
  "version": "0.4.3",
  "description": "Filesystem utilities using the Web File API",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/fs"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/fs#readme",
  "license": "MIT",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@remix-run/lazy-file": "remix-run/remix#preview/pr-11150&path:packages/lazy-file",
    "@remix-run/mime": "remix-run/remix#preview/pr-11150&path:packages/mime"
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/test": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "test:bun": "bun x --bun remix-test",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "file",
    "filesystem",
    "fs"
  ]
}

{
  "name": "@remix-run/typed-event-target",
  "version": "0.1.0",
  "description": "A typed EventTarget for web APIs",
  "author": "Ryan Florence <rpflorence@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/typed-event-target"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/typed-event-target#readme",
  "files": ["LICENSE", "README.md", "dist", "src"],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:"
  }
}

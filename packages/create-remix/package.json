{
  "name": "create-remix",
  "version": "0.0.0",
  "description": "Zero-install entrypoint for scaffolding Remix projects",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/create-remix"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/create-remix#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "bin": {
    "create-remix": "./dist/index.js"
  },
  "dependencies": {
    "@remix-run/cli": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "node --test './src/**/*.test.ts'",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "remix",
    "create",
    "scaffold",
    "cli",
    "project"
  ]
}

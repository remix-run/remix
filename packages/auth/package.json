{
  "name": "@remix-run/auth",
  "version": "0.1.1",
  "description": "Browser login, OAuth, and OIDC helpers for Remix",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/auth"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/auth#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/auth-middleware": "workspace:*",
    "@remix-run/cookie": "workspace:*",
    "@remix-run/fetch-router": "workspace:*",
    "@remix-run/form-data-middleware": "workspace:*",
    "@remix-run/headers": "workspace:*",
    "@remix-run/session": "workspace:*",
    "@remix-run/session-middleware": "workspace:*",
    "@remix-run/test": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:"
  },
  "dependencies": {
    "@remix-run/fetch-router": "remix-run/remix#preview/pr-11273&path:packages/fetch-router",
    "@remix-run/session": "remix-run/remix#preview/pr-11273&path:packages/session"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "test:bun": "bun x --bun remix-test",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "auth",
    "authentication",
    "oauth",
    "oidc",
    "atproto",
    "bluesky",
    "google",
    "github",
    "facebook",
    "x",
    "microsoft",
    "okta",
    "auth0",
    "login",
    "credentials",
    "session"
  ]
}

{
  "name": "@remix-run/route-pattern",
  "version": "0.20.1",
  "description": "Match and generate URLs with strong typing",
  "contributors": [
    "Michael Jackson <mjijackson@gmail.com>",
    "Pedro Cattori <pcattori@gmail.com>"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/route-pattern"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/route-pattern#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "src2",
    "!src/**/*.test.ts",
    "!src2/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./compile": "./src2/compile.ts",
    "./href": "./src2/href.ts",
    "./join": "./src2/join.ts",
    "./matcher": "./src2/matcher.ts",
    "./parse": "./src2/parse.ts",
    "./pattern": "./src2/pattern.ts",
    "./serialize": "./src2/serialize.ts",
    "./specificity": "./src2/specificity.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./specificity": {
        "types": "./dist/specificity.d.ts",
        "default": "./dist/specificity.js"
      },
      "./compile": {
        "types": "./dist/compile.d.ts",
        "default": "./dist/compile.js"
      },
      "./href": {
        "types": "./dist/href.d.ts",
        "default": "./dist/href.js"
      },
      "./join": {
        "types": "./dist/join.d.ts",
        "default": "./dist/join.js"
      },
      "./matcher": {
        "types": "./dist/matcher.d.ts",
        "default": "./dist/matcher.js"
      },
      "./parse": {
        "types": "./dist/parse.d.ts",
        "default": "./dist/parse.js"
      },
      "./pattern": {
        "types": "./dist/pattern.d.ts",
        "default": "./dist/pattern.js"
      },
      "./serialize": {
        "types": "./dist/serialize.d.ts",
        "default": "./dist/serialize.js"
      },
      "./package.json": "./package.json"
    }
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/test": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "dedent": "^1.7.1"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "test:bun": "bun x --bun remix-test",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "route",
    "pattern",
    "url",
    "match",
    "matcher"
  ]
}

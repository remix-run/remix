{
  "name": "@remix-run/test",
  "version": "0.0.0",
  "description": "A browser-based test framework for Remix components",
  "author": "Shopify Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/test"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/test#readme",
  "files": [
    "tsconfig.json",
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.*"
  ],
  "type": "module",
  "bin": {
    "remix-test": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./cli": "./src/cli.ts"
  },
  "publishConfig": {
    "bin": {
      "remix-test": "./dist/cli.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json",
      "./cli": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "node src/cli.ts",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@remix-run/component": "workspace:*",
    "@remix-run/fetch-router": "workspace:*",
    "@remix-run/node-fetch-server": "workspace:*",
    "esbuild": "^0.27.1",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "tsx": "^4.21.0",
    "v8-to-istanbul": "^9.3.0"
  },
  "peerDependencies": {
    "playwright": "^1.59.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "playwright": "catalog:"
  },
  "keywords": [
    "testing",
    "browser",
    "test",
    "remix",
    "component",
    "playwright"
  ]
}

{
  "name": "@remix-run/node-serve",
  "version": "0.0.0",
  "description": "Run fetch handlers on a high-throughput uWebSockets.js server",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/node-serve"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/node-serve#readme",
  "license": "MIT",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/test": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:"
  },
  "optionalDependencies": {
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.66.0"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "http",
    "server",
    "fetch",
    "web",
    "uwebsockets"
  ]
}

{
  "name": "@remix-run/theme",
  "version": "0.0.0",
  "description": "Theme contract and utility mixins for Remix components",
  "author": "Ryan Florence <rpflorence@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/theme"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/theme#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "devDependencies": {
    "@remix-run/component": "workspace:*",
    "@types/node": "catalog:",
    "@types/dom-navigation": "^1.0.7",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@typescript/native-preview": "catalog:",
    "playwright": "catalog:",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@remix-run/component": "workspace:^"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "remix",
    "theme",
    "theming",
    "design-tokens",
    "css-variables",
    "ui",
    "component-styling"
  ]
}

{
  "name": "@remix-run/node-hmr",
  "version": "0.0.0",
  "description": "Run Node.js applications with Hot Module Reloading",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/node-hmr"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/node-hmr#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/node-hmr.d.ts",
      "default": "./dist/node-hmr.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@remix-run/terminal": "remix-run/remix#preview/pr-11515&path:packages/terminal",
    "@remix-run/ui-hmr": "remix-run/remix#preview/pr-11515&path:packages/ui-hmr",
    "chokidar": "^5.0.0",
    "oxc-parser": "^0.121.0"
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:^",
    "@remix-run/node-tsx": "workspace:^",
    "@remix-run/test": "workspace:^",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "remix",
    "node",
    "hmr",
    "watch"
  ]
}

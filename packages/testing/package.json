{
  "name": "@remix-run/testing",
  "version": "0.0.0",
  "description": "A browser-based test framework for Remix components",
  "author": "Shopify Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/testing"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/testing#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "bin": {
    "remix-test": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "bin": {
      "remix-test": "./dist/cli.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "node src/cli.ts 'src/tests/*.test.{ts,tsx}'",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@remix-run/component": "workspace:*",
    "@remix-run/fetch-router": "workspace:*",
    "@remix-run/node-fetch-server": "workspace:*",
    "@remix-run/script-server": "workspace:*"
  },
  "peerDependencies": {
    "esbuild": "^0.25.0",
    "playwright": "^1.0.0",
    "tsx": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "tsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "decamelize": "^6.0.1"
  },
  "keywords": [
    "testing",
    "browser",
    "test",
    "remix",
    "component",
    "playwright"
  ]
}

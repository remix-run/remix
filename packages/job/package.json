{
  "name": "@remix-run/job",
  "version": "0.0.0",
  "description": "Background job scheduling for Remix",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/job"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/job#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "default": "./dist/storage.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "default": "./dist/worker.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@remix-run/data-schema": "remix-run/remix#preview/pr-11100&path:packages/data-schema"
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/test": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "job",
    "queue",
    "scheduler",
    "remix"
  ]
}

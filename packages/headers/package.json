{
  "name": "@remix-run/headers",
  "version": "0.21.1",
  "description": "A toolkit for working with HTTP headers in JavaScript",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/headers"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/headers#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./accept": {
      "types": "./dist/lib/accept.d.ts",
      "default": "./dist/lib/accept.js"
    },
    "./accept-encoding": {
      "types": "./dist/lib/accept-encoding.d.ts",
      "default": "./dist/lib/accept-encoding.js"
    },
    "./accept-language": {
      "types": "./dist/lib/accept-language.d.ts",
      "default": "./dist/lib/accept-language.js"
    },
    "./cache-control": {
      "types": "./dist/lib/cache-control.d.ts",
      "default": "./dist/lib/cache-control.js"
    },
    "./content-disposition": {
      "types": "./dist/lib/content-disposition.d.ts",
      "default": "./dist/lib/content-disposition.js"
    },
    "./content-range": {
      "types": "./dist/lib/content-range.d.ts",
      "default": "./dist/lib/content-range.js"
    },
    "./content-type": {
      "types": "./dist/lib/content-type.d.ts",
      "default": "./dist/lib/content-type.js"
    },
    "./cookie": {
      "types": "./dist/lib/cookie.d.ts",
      "default": "./dist/lib/cookie.js"
    },
    "./if-match": {
      "types": "./dist/lib/if-match.d.ts",
      "default": "./dist/lib/if-match.js"
    },
    "./if-none-match": {
      "types": "./dist/lib/if-none-match.d.ts",
      "default": "./dist/lib/if-none-match.js"
    },
    "./if-range": {
      "types": "./dist/lib/if-range.d.ts",
      "default": "./dist/lib/if-range.js"
    },
    "./range": {
      "types": "./dist/lib/range.d.ts",
      "default": "./dist/lib/range.js"
    },
    "./raw-headers": {
      "types": "./dist/lib/raw-headers.d.ts",
      "default": "./dist/lib/raw-headers.js"
    },
    "./set-cookie": {
      "types": "./dist/lib/set-cookie.d.ts",
      "default": "./dist/lib/set-cookie.js"
    },
    "./vary": {
      "types": "./dist/lib/vary.d.ts",
      "default": "./dist/lib/vary.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/test": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "test:bun": "bun x --bun remix-test",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "fetch",
    "http",
    "header",
    "headers",
    "http-headers",
    "request-headers",
    "response-headers",
    "content-negotiation",
    "cookies",
    "set-cookie",
    "cache-control",
    "content-type",
    "accept",
    "accept-encoding",
    "accept-language",
    "content-disposition",
    "if-none-match",
    "etag",
    "user-agent",
    "host",
    "last-modified"
  ]
}

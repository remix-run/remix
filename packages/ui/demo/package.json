{
  "name": "ui-demo",
  "private": true,
  "type": "module",
  "dependencies": {
    "remix": "workspace:*",
    "@remix-run/ui": "workspace:*"
  },
  "devDependencies": {
    "@types/dom-navigation": "^1.0.7",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "esbuild": "^0.25.10",
    "node-html-parser": "^7.0.2"
  },
  "scripts": {
    "build:browser": "node --import remix/node-tsx scripts/build-browser.ts",
    "dev": "pnpm run --filter \".\" --parallel \"/^dev:/\"",
    "dev:server": "NODE_ENV=development node --import remix/node-tsx server.ts",
    "dev:browser": "node --import remix/node-tsx scripts/build-browser.ts --watch",
    "prerender": "pnpm run build:browser && node --import remix/node-tsx scripts/prerender.ts",
    "prerender:serve": "npx http-server -p 3000 build/site",
    "start": "pnpm run build:browser && node --import remix/node-tsx server.ts",
    "typecheck": "tsc --noEmit"
  }
}

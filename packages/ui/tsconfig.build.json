{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.demo.ts",
    "src/**/*.demo.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test"
  ]
}

        "default": "./dist/jsx-runtime.js"
      },
      "./listbox": {
        "types": "./dist/listbox/index.d.ts",
        "default": "./dist/listbox/index.js"
      },
      "./menu": {
        "types": "./dist/menu/index.d.ts",
        "default": "./dist/menu/index.js"
      },
      "./menu/primitives": {
        "types": "./dist/menu/primitives.d.ts",

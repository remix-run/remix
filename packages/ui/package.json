  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/test": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "playwright": "catalog:",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/dom-navigation": "^1.0.7"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "lint": "pnpm -w exec oxlint packages/ui --max-warnings=0",
    "lint:fix": "pnpm -w exec oxlint packages/ui --fix --max-warnings=0",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",

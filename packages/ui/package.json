{
  "name": "@remix-run/ui",
  "version": "0.3.0",
  "description": "UI runtime, headless primitives, and styled components for Remix",
  "author": "Ryan Florence <rpflorence@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/ui#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.demo.ts",
    "!src/**/*.demo.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./animation": {
      "types": "./dist/animation/index.d.ts",
      "default": "./dist/animation/index.js"
    },
    "./accordion": {
      "types": "./dist/primitives/accordion/accordion.d.ts",
      "default": "./dist/primitives/accordion/accordion.js"
    },
    "./anchor": {
      "types": "./dist/primitives/anchor/anchor.d.ts",
      "default": "./dist/primitives/anchor/anchor.js"
    },
    "./combobox": {
      "types": "./dist/primitives/combobox/combobox.d.ts",
      "default": "./dist/primitives/combobox/combobox.js"
    },
    "./components/accordion": {
      "types": "./dist/components/accordion/accordion.d.ts",
      "default": "./dist/components/accordion/accordion.js"
    },
    "./components/breadcrumbs": {
      "types": "./dist/components/breadcrumbs/breadcrumbs.d.ts",
      "default": "./dist/components/breadcrumbs/breadcrumbs.js"
    },
    "./components/button": {
      "types": "./dist/components/button/button.d.ts",
      "default": "./dist/components/button/button.js"
    },
    "./components/combobox": {
      "types": "./dist/components/combobox/combobox.d.ts",
      "default": "./dist/components/combobox/combobox.js"
    },
    "./components/menu": {
      "types": "./dist/components/menu/menu.d.ts",
      "default": "./dist/components/menu/menu.js"
    },
    "./components/select": {
      "types": "./dist/components/select/select.d.ts",
      "default": "./dist/components/select/select.js"
    },
    "./components/tabs": {
      "types": "./dist/components/tabs/tabs.d.ts",
      "default": "./dist/components/tabs/tabs.js"
    },
    "./dev/refresh": {
      "types": "./dist/dev-refresh.d.ts",
      "default": "./dist/dev-refresh.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    },
    "./listbox": {
      "types": "./dist/primitives/listbox/listbox.d.ts",
      "default": "./dist/primitives/listbox/listbox.js"
    },
    "./menu": {
      "types": "./dist/primitives/menu/menu.d.ts",
      "default": "./dist/primitives/menu/menu.js"
    },
    "./popover": {
      "types": "./dist/primitives/popover/popover.d.ts",
      "default": "./dist/primitives/popover/popover.js"
    },
    "./select": {
      "types": "./dist/primitives/select/select.d.ts",
      "default": "./dist/primitives/select/select.js"
    },
    "./tabs": {
      "types": "./dist/primitives/tabs/tabs.d.ts",
      "default": "./dist/primitives/tabs/tabs.js"
    },
    "./server": {
      "types": "./dist/server/stream.d.ts",
      "default": "./dist/server/stream.js"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "default": "./dist/test.js"
    },
    "./scroll-lock": {
      "types": "./dist/utils/scroll-lock.d.ts",
      "default": "./dist/utils/scroll-lock.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/test": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "playwright": "catalog:",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/dom-navigation": "^1.0.7"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "lint": "pnpm -w exec oxlint packages/ui --max-warnings=0",
    "lint:fix": "pnpm -w exec oxlint packages/ui --fix --max-warnings=0",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "test:coverage": "remix-test --coverage",
    "test:watch": "remix-test --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "remix",
    "ui",
    "headless",
    "components",
    "mixins",
    "runtime",
    "primitives"
  ]
}

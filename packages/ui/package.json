{
  "name": "@remix-run/ui",
  "version": "0.3.0",
  "description": "UI runtime, headless primitives, and styled components for Remix",
  "author": "Ryan Florence <rpflorence@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/ui#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.demo.ts",
    "!src/**/*.demo.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./accordion": {
      "types": "./dist/accordion/index.d.ts",
      "default": "./dist/accordion/index.js"
    },
    "./accordion/primitives": {
      "types": "./dist/accordion/primitives.d.ts",
      "default": "./dist/accordion/primitives.js"
    },
    "./anchor": {
      "types": "./dist/anchor/index.d.ts",
      "default": "./dist/anchor/index.js"
    },
    "./animation": {
      "types": "./dist/animation/index.d.ts",
      "default": "./dist/animation/index.js"
    },
    "./breadcrumbs": {
      "types": "./dist/breadcrumbs/index.d.ts",
      "default": "./dist/breadcrumbs/index.js"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "default": "./dist/button/index.js"
    },
    "./checkbox": {
      "types": "./dist/checkbox/index.d.ts",
      "default": "./dist/checkbox/index.js"
    },
    "./combobox": {
      "types": "./dist/combobox/index.d.ts",
      "default": "./dist/combobox/index.js"
    },
    "./combobox/primitives": {
      "types": "./dist/combobox/primitives.d.ts",
      "default": "./dist/combobox/primitives.js"
    },
    "./input": {
      "types": "./dist/input/index.d.ts",
      "default": "./dist/input/index.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    },
    "./listbox": {
      "types": "./dist/listbox/index.d.ts",
      "default": "./dist/listbox/index.js"
    },
    "./menu": {
      "types": "./dist/menu/index.d.ts",
      "default": "./dist/menu/index.js"
    },
    "./menu/primitives": {
      "types": "./dist/menu/primitives.d.ts",
      "default": "./dist/menu/primitives.js"
    },
    "./popover": {
      "types": "./dist/popover/index.d.ts",
      "default": "./dist/popover/index.js"
    },
    "./radio": {
      "types": "./dist/radio/index.d.ts",
      "default": "./dist/radio/index.js"
    },
    "./select": {
      "types": "./dist/select/index.d.ts",
      "default": "./dist/select/index.js"
    },
    "./select/primitives": {
      "types": "./dist/select/primitives.d.ts",
      "default": "./dist/select/primitives.js"
    },
    "./server": {
      "types": "./dist/server/stream.d.ts",
      "default": "./dist/server/stream.js"
    },
    "./tabs": {
      "types": "./dist/tabs/index.d.ts",
      "default": "./dist/tabs/index.js"
    },
    "./tabs/primitives": {
      "types": "./dist/tabs/primitives.d.ts",
      "default": "./dist/tabs/primitives.js"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "default": "./dist/test.js"
    },
    "./toggle": {
      "types": "./dist/toggle/index.d.ts",
      "default": "./dist/toggle/index.js"
    },
    "./toggle/primitives": {
      "types": "./dist/toggle/primitives.d.ts",
      "default": "./dist/toggle/primitives.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/test": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "playwright": "catalog:",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/dom-navigation": "^1.0.7"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "lint": "pnpm -w exec oxlint packages/ui --max-warnings=0",
    "lint:fix": "pnpm -w exec oxlint packages/ui --fix --max-warnings=0",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "test:coverage": "remix-test --coverage",
    "test:watch": "remix-test --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "remix",
    "ui",
    "headless",
    "components",
    "mixins",
    "runtime",
    "primitives"
  ]
}

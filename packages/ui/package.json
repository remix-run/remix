{
  "name": "@remix-run/ui",
  "version": "0.0.0",
  "description": "UI tokens, mixins, and glyphs for Remix components",
  "author": "Ryan Florence <rpflorence@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/ui#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@remix-run/component": "workspace:*",
    "@types/node": "catalog:",
    "@types/dom-navigation": "^1.0.7",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@typescript/native-preview": "catalog:",
    "jsdom": "^26.1.0",
    "playwright": "catalog:",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@remix-run/component": "remix-run/remix#preview/pr-11178&path:packages/component"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "remix",
    "ui",
    "theming",
    "design-tokens",
    "css-variables",
    "mixins",
    "glyphs",
    "component-styling"
  ]
}

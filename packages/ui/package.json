{
  "name": "@remix-run/ui",
  "version": "0.0.0",
  "description": "UI tokens, mixins, and glyphs for Remix components",
  "author": "Ryan Florence <rpflorence@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/ui#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./accordion": {
      "types": "./src/accordion.ts",
      "default": "./src/accordion.ts"
    },
    "./anchor": {
      "types": "./src/lib/anchor/anchor.ts",
      "default": "./src/lib/anchor/anchor.ts"
    },
    "./breadcrumbs": {
      "types": "./src/lib/breadcrumbs/breadcrumbs.tsx",
      "default": "./src/lib/breadcrumbs/breadcrumbs.tsx"
    },
    "./button": {
      "types": "./src/button.ts",
      "default": "./src/button.ts"
    },
    "./combobox": {
      "types": "./src/combobox.ts",
      "default": "./src/combobox.ts"
    },
    "./glyph": {
      "types": "./src/lib/glyph/glyph.tsx",
      "default": "./src/lib/glyph/glyph.tsx"
    },
    "./listbox": {
      "types": "./src/listbox.ts",
      "default": "./src/listbox.ts"
    },
    "./menu": {
      "types": "./src/menu.ts",
      "default": "./src/menu.ts"
    },
    "./popover": {
      "types": "./src/popover.ts",
      "default": "./src/popover.ts"
    },
    "./select": {
      "types": "./src/select.ts",
      "default": "./src/select.ts"
    },
    "./separator": {
      "types": "./src/separator.ts",
      "default": "./src/separator.ts"
    },
    "./theme": {
      "types": "./src/lib/theme/theme.ts",
      "default": "./src/lib/theme/theme.ts"
    },
    "./scroll-lock": {
      "types": "./src/lib/utils/scroll-lock.ts",
      "default": "./src/lib/utils/scroll-lock.ts"
    },
    "./on-outside-pointer-down": {
      "types": "./src/lib/utils/outside-pointerdown.ts",
      "default": "./src/lib/utils/outside-pointerdown.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      "./accordion": {
        "types": "./dist/accordion.d.ts",
        "default": "./dist/accordion.js"
      },
      "./anchor": {
        "types": "./dist/lib/anchor/anchor.d.ts",
        "default": "./dist/lib/anchor/anchor.js"
      },
      "./breadcrumbs": {
        "types": "./dist/lib/breadcrumbs/breadcrumbs.d.ts",
        "default": "./dist/lib/breadcrumbs/breadcrumbs.js"
      },
      "./button": {
        "types": "./dist/button.d.ts",
        "default": "./dist/button.js"
      },
      "./combobox": {
        "types": "./dist/combobox.d.ts",
        "default": "./dist/combobox.js"
      },
      "./glyph": {
        "types": "./dist/lib/glyph/glyph.d.ts",
        "default": "./dist/lib/glyph/glyph.js"
      },
      "./listbox": {
        "types": "./dist/listbox.d.ts",
        "default": "./dist/listbox.js"
      },
      "./menu": {
        "types": "./dist/menu.d.ts",
        "default": "./dist/menu.js"
      },
      "./popover": {
        "types": "./dist/popover.d.ts",
        "default": "./dist/popover.js"
      },
      "./select": {
        "types": "./dist/select.d.ts",
        "default": "./dist/select.js"
      },
      "./separator": {
        "types": "./dist/separator.d.ts",
        "default": "./dist/separator.js"
      },
      "./theme": {
        "types": "./dist/lib/theme/theme.d.ts",
        "default": "./dist/lib/theme/theme.js"
      },
      "./scroll-lock": {
        "types": "./dist/lib/utils/scroll-lock.d.ts",
        "default": "./dist/lib/utils/scroll-lock.js"
      },
      "./on-outside-pointer-down": {
        "types": "./dist/lib/utils/outside-pointerdown.d.ts",
        "default": "./dist/lib/utils/outside-pointerdown.js"
      },
      "./package.json": "./package.json"
    }
  },
  "devDependencies": {
    "@remix-run/component": "workspace:*",
    "@types/node": "catalog:",
    "@types/dom-navigation": "^1.0.7",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@typescript/native-preview": "catalog:",
    "playwright": "catalog:",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@remix-run/component": "workspace:^"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "lint": "pnpm -w exec oxlint packages/ui -A all --quiet",
    "lint:fix": "pnpm -w exec oxlint packages/ui -A all --fix --quiet",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "remix",
    "ui",
    "theming",
    "design-tokens",
    "css-variables",
    "mixins",
    "glyphs",
    "component-styling"
  ]
}

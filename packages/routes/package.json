{
  "name": "@remix-run/routes",
  "version": "0.0.0",
  "description": "Typed route definitions and URL helpers for Remix apps",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/routes"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/routes#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/test": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:"
  },
  "dependencies": {
    "@remix-run/route-pattern": "remix-run/remix#preview/pr-11361&path:packages/route-pattern"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "test:bun": "bun x --bun remix-test",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "route",
    "routes",
    "routing",
    "url",
    "pattern",
    "href"
  ]
}

{
  "name": "@remix-run/render-middleware",
  "version": "0.1.4",
  "description": "Conventional Remix UI and custom request-scoped render middleware",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/render-middleware"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/render-middleware#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/fetch-router": "workspace:*",
    "@remix-run/test": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@remix-run/assets": "remix-run/remix#preview/pr-11607&path:packages/assets",
    "@remix-run/fetch-router": "remix-run/remix#preview/pr-11607&path:packages/fetch-router",
    "@remix-run/response": "remix-run/remix#preview/pr-11607&path:packages/response",
    "@remix-run/ui": "remix-run/remix#preview/pr-11607&path:packages/ui"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "test:bun": "bun x --bun remix-test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "fetch",
    "router",
    "middleware",
    "render",
    "renderer",
    "response"
  ]
}

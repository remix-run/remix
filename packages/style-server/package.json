{
  "name": "@remix-run/style-server",
  "version": "0.0.0",
  "description": "Fetch-based server for compiling and serving CSS files on demand.",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/style-server"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/style-server#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "bench": "pnpm --dir ./bench run bench",
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "node --disable-warning=ExperimentalWarning --test './src/**/*.test.ts'",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "remix",
    "styles",
    "css",
    "style-server",
    "server"
  ],
  "dependencies": {
    "@remix-run/fs": "remix-run/remix#preview/pr-11243&path:packages/fs",
    "@remix-run/headers": "remix-run/remix#preview/pr-11243&path:packages/headers",
    "@remix-run/response": "remix-run/remix#preview/pr-11243&path:packages/response",
    "@remix-run/route-pattern": "remix-run/remix#preview/pr-11243&path:packages/route-pattern",
    "browserslist": "^4.28.2",
    "chokidar": "^5.0.0",
    "lightningcss": "^1.32.0",
    "magic-string": "^0.30.21",
    "source-map-js": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}

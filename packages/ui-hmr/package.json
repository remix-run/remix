{
  "name": "@remix-run/ui-hmr",
  "version": "0.0.0",
  "description": "Hot module replacement runtime and transforms for Remix UI components",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/ui-hmr"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/ui-hmr#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./browser-module-hooks": "./src/browser-module-hooks.ts",
    "./browser-runtime": "./src/browser-runtime.ts",
    "./node": "./src/node.ts",
    "./server-runtime": "./src/server-runtime.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./browser-module-hooks": {
        "types": "./dist/browser-module-hooks.d.ts",
        "default": "./dist/browser-module-hooks.js"
      },
      "./browser-runtime": {
        "types": "./dist/browser-runtime.d.ts",
        "default": "./dist/browser-runtime.js"
      },
      "./node": {
        "types": "./dist/node.d.ts",
        "default": "./dist/node.js"
      },
      "./server-runtime": {
        "types": "./dist/server-runtime.d.ts",
        "default": "./dist/server-runtime.js"
      },
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.121.0",
    "source-map-js": "^1.2.1"
  },
  "devDependencies": {
    "@remix-run/assert": "workspace:*",
    "@remix-run/assets": "workspace:^",
    "@remix-run/fetch-proxy": "workspace:*",
    "@remix-run/node-fetch-server": "workspace:*",
    "@remix-run/node-hmr": "workspace:^",
    "@remix-run/node-tsx": "workspace:^",
    "@remix-run/test": "workspace:*",
    "@remix-run/ui": "workspace:*",
    "@types/dom-navigation": "^1.0.7",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "chokidar": "^5.0.0"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "remix",
    "component",
    "hmr",
    "transform",
    "ui"
  ]
}

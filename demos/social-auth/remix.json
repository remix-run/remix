{
  "$schema": "https://remix.run/schemas/remix.json",
  "db": {
    "adapter": {
      "type": "sqlite",
      "filename": "./db/social-auth.sqlite",
      "foreignKeys": true
    },
    "migrations": {
      "directory": "./db/migrations"
    },
    "seed": {
      "module": "./app/data/seed.ts",
      "export": "seed"
    }
  }
}

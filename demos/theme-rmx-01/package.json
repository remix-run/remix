{
  "name": "theme-rmx-01-demo",
  "private": true,
  "type": "module",
  "dependencies": {
    "@remix-run/theme": "workspace:*",
    "remix": "workspace:*"
  },
  "devDependencies": {
    "@types/dom-navigation": "^1.0.7",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "playwright": "catalog:",
    "tsx": "catalog:"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server.ts",
    "screenshot": "node --import tsx review/screenshot.ts",
    "screenshot:card": "node --import tsx review/screenshot.ts --selector='#cards article:first-of-type' --name='surface-card'",
    "start": "tsx server.ts",
    "typecheck": "tsc --noEmit"
  }
}

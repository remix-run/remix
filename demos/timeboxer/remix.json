{
  "$schema": "https://remix.run/schemas/remix.json",
  "db": {
    "adapter": {
      "type": "sqlite",
      "filename": {
        "env": "DATABASE_URL",
        "default": "./db/timebox.sqlite"
      },
      "foreignKeys": true
    },
    "migrations": {
      "directory": "./db/migrations"
    },
    "seed": {
      "module": "./app/data/seed.ts",
      "export": "seed"
    }
  }
}

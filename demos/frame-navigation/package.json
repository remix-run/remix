{
  "name": "frame-navigation-demo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.3.0"
  },
  "dependencies": {
    "remix": "workspace:*"
  },
  "devDependencies": {
    "@types/dom-navigation": "^1.0.7",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "esbuild": "^0.25.10",
    "tsx": "catalog:"
  },
  "scripts": {
    "dev": "pnpm run --filter \".\" --parallel \"/^dev:/\"",
    "dev:server": "NODE_ENV=development tsx watch server.ts",
    "dev:browser": "esbuild app/assets/*.tsx --outbase=app/assets --outdir=public/assets --bundle --format=esm --entry-names='[dir]/[name]' --chunk-names='chunks/[name]-[hash]' --sourcemap --watch",
    "start": "tsx server.ts",
    "typecheck": "tsc --noEmit"
  }
}
